# Auth
AUTH_SECRET=<openssl rand -base64 32>
AUTH_TRUST_HOST=true
AUTH_GOOGLE_ID=<Google OAuth Client ID>
AUTH_GOOGLE_SECRET=<Google OAuth Client Secret>

# Admin access control
ADMIN_EMAILS="kkhdevs@gmail.com"

# Region config
REGIONS='[{"id":"kr","name":"한국","domain":"k-esg.esgohq.com","flag":"🇰🇷"},{"id":"vn","name":"베트남","domain":"vn.esgohq.com","flag":"🇻🇳"},{"id":"mx","name":"멕시코","domain":"mx.esgohq.com","flag":"🇲🇽"}]'

# Region DB URLs
DATABASE_URL_KR="postgresql://esgo:esgo_local@localhost:5433/esgo"
DATABASE_URL_VN="postgresql://esgo:esgo_local@localhost:5434/esgo_vn"
DATABASE_URL_MX="postgresql://esgo:esgo_local@localhost:5435/esgo_mx"

# AWS S3
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=<your-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-secret-access-key>

# Internal API
INTERNAL_API_KEY="change-me-in-production"

# Logging
LOG_LEVEL=info

# App
NODE_ENV=development
