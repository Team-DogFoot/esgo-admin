generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client-vn"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AggregationSet {
  id                     String                   @id
  workspaceId            String
  esgItemCode            String
  name                   String
  period                 String
  status                 AggregationSetStatus     @default(DRAFT)
  result                 Json?
  errorMessage           String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime
  Workspace              Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  AggregationSetDocument AggregationSetDocument[]

  @@unique([workspaceId, esgItemCode, period])
  @@index([workspaceId])
}

model AggregationSetDocument {
  id               String         @id
  aggregationSetId String
  documentId       String
  documentType     String
  label            String?
  included         Boolean        @default(true)
  extractedValue   Json?
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  AggregationSet   AggregationSet @relation(fields: [aggregationSetId], references: [id], onDelete: Cascade)
  Document         Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([aggregationSetId, documentId])
  @@index([aggregationSetId])
}

model AiUsageLog {
  id                String     @id
  workspaceId       String
  provider          AiProvider
  model             String?
  operation         String
  promptTokens      Int?
  candidateTokens   Int?
  totalTokens       Int?
  cachedTokens      Int?
  cacheTokenCount   Int?
  cacheTtlSeconds   Int?
  pageCount         Int?
  imageCount        Int?
  estimatedCostUsd  Float?
  documentId        String?
  pipelineSessionId String?
  durationMs        Int?
  success           Boolean    @default(true)
  errorMessage      String?
  createdAt         DateTime   @default(now())
  Workspace         Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([provider, createdAt])
  @@index([workspaceId, createdAt])
}

model Document {
  id                     String                   @id
  workspaceId            String
  uploaderId             String
  fileName               String
  displayName            String?
  s3Key                  String
  s3Url                  String
  size                   BigInt
  contentType            String?
  status                 DocumentStatus           @default(UPLOADED)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime
  AggregationSetDocument AggregationSetDocument[]
  User                   User                     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  Workspace              Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  DocumentItemLink       DocumentItemLink[]
  EsgSummary             EsgSummary[]
  PipelineSession        PipelineSession[]

  @@index([workspaceId, createdAt])
}

model DocumentItemLink {
  id          String         @id
  workspaceId String
  documentId  String
  esgItemCode String
  source      DataSource
  summary     String?
  data        Json?
  phase       PipelinePhase?
  createdAt   DateTime       @default(now())
  Document    Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  Workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, documentId, esgItemCode])
  @@index([workspaceId, esgItemCode])
}

model EsgSummary {
  id                String          @id
  workspaceId       String
  esgItemCode       String
  status            EsgAnswerStatus @default(NOT_STARTED)
  locked            Boolean         @default(false)
  summary           String?
  source            DataSource?
  documentId        String?
  pipelinePhase     PipelinePhase?
  sourceDocumentIds Json?
  mergeStrategy     String?
  fieldSources      Json?
  filledFields      Int             @default(0)
  totalFields       Int             @default(0)
  completionRate    Int             @default(0)
  grade             String?
  keyMetrics        Json?
  evidenceDetails   Json?
  naReason          NaReasonType?
  naRecommendedByAi Boolean         @default(false)
  updatedAt         DateTime
  createdAt         DateTime        @default(now())
  Document          Document?       @relation(fields: [documentId], references: [id])
  Workspace         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, esgItemCode])
  @@index([workspaceId, status])
}

