  EsgE52           EsgE52?
  EsgE53           EsgE53?
  EsgE54           EsgE54?
  EsgE55           EsgE55?
  EsgE61           EsgE61?
  EsgE62           EsgE62?
  EsgE71           EsgE71?
  EsgE72           EsgE72?
  EsgE81           EsgE81?
  EsgE91           EsgE91?
  EsgE92           EsgE92?
  EsgE93           EsgE93?
  EsgG11           EsgG11?
  EsgG12           EsgG12?
  EsgG13           EsgG13?
  EsgG21           EsgG21?
  EsgG22           EsgG22?
  EsgG23           EsgG23?
  EsgG31           EsgG31?
  EsgG32           EsgG32?
  EsgG33           EsgG33?
  EsgG41           EsgG41?
  EsgG42           EsgG42?
  EsgG43           EsgG43?
  EsgG51           EsgG51?
  EsgG52           EsgG52?
  EsgG53           EsgG53?
  EsgG54           EsgG54?
  EsgG61           EsgG61?
  EsgP11           EsgP11?
  EsgP12           EsgP12?
  EsgP21           EsgP21?
  EsgP22           EsgP22?
  EsgP31           EsgP31?
  EsgS11           EsgS11?
  EsgS12           EsgS12?
  EsgS13           EsgS13?
  EsgS21           EsgS21?
  EsgS22           EsgS22?
  EsgS23           EsgS23?
  EsgS31           EsgS31?
  EsgS32           EsgS32?
  EsgS33           EsgS33?
  EsgS41           EsgS41?
  EsgS42           EsgS42?
  EsgS43           EsgS43?
  EsgS51           EsgS51?
  EsgS52           EsgS52?
  EsgS53           EsgS53?
  EsgS61           EsgS61?
  EsgS62           EsgS62?
  EsgS71           EsgS71?
  EsgS72           EsgS72?
  EsgS81           EsgS81?
  EsgS82           EsgS82?
  EsgS91           EsgS91?
  esgSummaries     EsgSummary[]
  Invitation       Invitation[]
  Payment          Payment[]
  PipelineSession  PipelineSession[]
  Report           Report[]
  subscription     Subscription?
  createdBy        User?              @relation("createdWorkspaces", fields: [createdById], references: [id])
  members          WorkspaceMember[]
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        Role      @default(VIEWER)
  joinedAt    DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Document {
  id                     String                   @id @default(cuid())
  workspaceId            String
  uploaderId             String
  fileName               String
  displayName            String?
  s3Key                  String
  s3Url                  String
  size                   BigInt
  contentType            String?
  status                 DocumentStatus           @default(UPLOADED)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime
  AggregationSetDocument AggregationSetDocument[]
  User                   User                     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  workspace              Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  DocumentItemLink       DocumentItemLink[]
  EsgSummary             EsgSummary[]
  PipelineSession        PipelineSession[]
}

model EsgSummary {
  id                String          @id @default(cuid())
  workspaceId       String
  esgItemCode       String
  status            EsgAnswerStatus @default(NOT_STARTED)
  locked            Boolean         @default(false)
  summary           String?
  source            DataSource?
  documentId        String?
  pipelinePhase     PipelinePhase?
  sourceDocumentIds Json?
  mergeStrategy     String?
  fieldSources      Json?
  filledFields      Int             @default(0)
  totalFields       Int             @default(0)
  completionRate    Int             @default(0)
  updatedAt         DateTime        @updatedAt
  createdAt         DateTime        @default(now())
  Document          Document?       @relation(fields: [documentId], references: [id])
  workspace         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, esgItemCode])
}

model CreditLedger {
  id          String     @id @default(cuid())
  workspaceId String
  amount      Int
  balance     Int
  type        CreditType
  reason      String
  referenceId String?
  createdAt   DateTime   @default(now())
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
}

model Plan {
  id             String         @id @default(cuid())
  code           PlanCode       @unique
  name           String
  monthlyPrice   Int
  initialCredits Int
  monthlyCredits Int
  features       Json           @default("[]")
  maxMembers     Int            @default(0)
  maxDocuments   Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime
  subscriptions  Subscription[]
}

model Subscription {
  id                    String             @id @default(cuid())
  workspaceId           String             @unique
  planId                String
  status                SubscriptionStatus @default(ACTIVE)
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  portoneSubscriptionId String?
  portoneBillingKey     String?
  canceledAt            DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime
  plan                  Plan               @relation(fields: [planId], references: [id])
  workspace             Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AggregationSet {
  id                     String                   @id
  workspaceId            String
  esgItemCode            String
  name                   String
  period                 String
  status                 AggregationSetStatus     @default(DRAFT)
  result                 Json?
  errorMessage           String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime
  Workspace              Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  AggregationSetDocument AggregationSetDocument[]

  @@unique([workspaceId, esgItemCode, period])
  @@index([workspaceId])
}

model AggregationSetDocument {
  id               String         @id
  aggregationSetId String
  documentId       String
  documentType     String
  label            String?
  included         Boolean        @default(true)
  extractedValue   Json?
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  AggregationSet   AggregationSet @relation(fields: [aggregationSetId], references: [id], onDelete: Cascade)
  Document         Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([aggregationSetId, documentId])
  @@index([aggregationSetId])
}

model DocumentItemLink {
  id          String         @id
  workspaceId String
  documentId  String
  esgItemCode String
  source      DataSource
  summary     String?
  data        Json?
  phase       PipelinePhase?
  createdAt   DateTime       @default(now())
  Document    Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  Workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, documentId, esgItemCode])
  @@index([workspaceId, esgItemCode])
}

