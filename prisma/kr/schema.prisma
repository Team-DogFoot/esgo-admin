generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client-kr"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String            @id @default(cuid())
  name              String?
  email             String?           @unique
  emailVerified     DateTime?
  image             String?
  activeWorkspaceId String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  Account           Account[]
  Document          Document[]
  Report            Report[]
  createdWorkspaces Workspace[]       @relation("createdWorkspaces")
  memberships       WorkspaceMember[]
}

model Workspace {
  id               String             @id @default(cuid())
  name             String
  businessNumber   String
  createdById      String?
  creditBalance    Int                @default(0)
  planCode         PlanCode           @default(FREE)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  AggregationSet   AggregationSet[]
  creditLedgers    CreditLedger[]
  documents        Document[]
  DocumentItemLink DocumentItemLink[]
  EsgE101          EsgE101?
  EsgE11           EsgE11?
  EsgE111          EsgE111?
  EsgE12           EsgE12?
  EsgE21           EsgE21?
  EsgE22           EsgE22?
  EsgE31           EsgE31?
  EsgE32           EsgE32?
  EsgE33           EsgE33?
  EsgE41           EsgE41?
  EsgE42           EsgE42?
  EsgE43           EsgE43?
