model Invitation {
  id          String    @id
  email       String
  workspaceId String
  role        Role      @default(VIEWER)
  token       String    @unique
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  Workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([email, workspaceId])
}

model Payment {
  id               String        @id
  workspaceId      String
  type             PaymentType
  amount           Int
  credits          Int?
  status           PaymentStatus @default(PENDING)
  portonePaymentId String?       @unique
  receiptUrl       String?
  failReason       String?
  paidAt           DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime
  Workspace        Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
}

model PipelineSession {
  id           String        @id
  workspaceId  String
  documentId   String
  sessionId    String        @unique
  currentPhase PipelinePhase
  autoMode     Boolean       @default(false)
  state        Json?
  errorCount   Int           @default(0)
  lastError    String?
  durationMs   Int?
  startedAt    DateTime      @default(now())
  completedAt  DateTime?
  Document     Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  Workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Report {
  id          String    @id
  workspaceId String
  title       String
  data        Json
  createdById String
  generatedAt DateTime  @default(now())
  User        User      @relation(fields: [createdById], references: [id])
  Workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, generatedAt(sort: Desc)])
}

model mcp_oauth_clients {
  id                      String             @id
  clientId                String             @unique
  clientSecret            String?
  clientSecretExpiresAt   Int?
  clientIdIssuedAt        Int
  redirectUris            Json
  clientName              String?
  tokenEndpointAuthMethod String?
  grantTypes              Json?
  responseTypes           Json?
  createdAt               DateTime           @default(now())
  mcp_oauth_codes         mcp_oauth_codes[]
  mcp_oauth_tokens        mcp_oauth_tokens[]
}

model mcp_oauth_codes {
  id                  String            @id
  code                String            @unique
  clientId            String
  userId              String
  workspaceId         String
  redirectUri         String
  codeChallenge       String
  codeChallengeMethod String            @default("S256")
  scopes              Json
  expiresAt           DateTime
  used                Boolean           @default(false)
  createdAt           DateTime          @default(now())
  mcp_oauth_clients   mcp_oauth_clients @relation(fields: [clientId], references: [clientId], onDelete: Cascade)

  @@index([expiresAt])
}

model mcp_oauth_tokens {
  id                String            @id
  tokenHash         String            @unique
  refreshHash       String?           @unique
  clientId          String
  userId            String
  workspaceId       String
  scopes            Json
  expiresAt         DateTime
  refreshExpiresAt  DateTime?
  revoked           Boolean           @default(false)
  lastUsedAt        DateTime?
  createdAt         DateTime          @default(now())
  mcp_oauth_clients mcp_oauth_clients @relation(fields: [clientId], references: [clientId], onDelete: Cascade)

  @@index([userId, workspaceId])
}

